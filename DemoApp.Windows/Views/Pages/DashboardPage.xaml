<Page
  x:Class="DemoApp.Windows.Views.Pages.DashboardPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:DemoApp.Windows.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="DashboardPage"
  d:DataContext="{d:DesignInstance local:DashboardPage,
                                     IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
  <StackPanel VerticalAlignment="Top">
    <Border
      MaxWidth="720"
      Padding="22"
      HorizontalAlignment="Left"
      Background="{DynamicResource AccentFillColorSecondaryBrush}"
      CornerRadius="8"
    >
      <StackPanel>
        <TextBlock FontSize="14" FontWeight="Medium" Text="Current demo message" />
        <TextBlock
          Margin="0,8,0,0"
          FontSize="26"
          FontWeight="Medium"
          Text="{Binding ViewModel.DemoMessage, Mode=OneWay}"
          TextWrapping="Wrap"
        />
      </StackPanel>
    </Border>

    <Grid Margin="0,18,0,0" HorizontalAlignment="Left">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <ui:Button
        Grid.Column="0"
        Command="{Binding ViewModel.CounterIncrementCommand, Mode=OneWay}"
        Content="Click me!"
        Icon="Fluent24"
      />
      <TextBlock
        Grid.Column="1"
        Margin="12,0,0,0"
        VerticalAlignment="Center"
        Text="{Binding ViewModel.Counter, Mode=OneWay}"
      />
    </Grid>
  </StackPanel>
</Page>
