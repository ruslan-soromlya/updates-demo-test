<Page
  x:Class="DemoApp.Windows.Views.Pages.UpdatePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:DemoApp.Windows.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="UpdatePage"
  d:DataContext="{d:DesignInstance local:UpdatePage,
                                     IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
  <StackPanel MaxWidth="720" HorizontalAlignment="Left">
    <TextBlock FontSize="20" FontWeight="Medium" Text="Updates" />
    <TextBlock Margin="0,12,0,0" Text="Update source" />
    <TextBox Margin="0,6,0,0" Text="{Binding ViewModel.UpdateSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

    <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
      <ui:Button Command="{Binding ViewModel.CheckForUpdatesCommand}" Content="Check for updates" />
      <ui:Button Margin="8,0,0,0" Command="{Binding ViewModel.DownloadUpdateCommand}" Content="Download update" />
      <ui:Button Margin="8,0,0,0" Command="{Binding ViewModel.ApplyUpdateCommand}" Content="Restart and update" />
    </StackPanel>

    <ProgressBar Margin="0,16,0,0" Height="8" Maximum="100" Value="{Binding ViewModel.DownloadProgress}" />

    <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="{Binding ViewModel.Status}" TextWrapping="Wrap" />
    <TextBlock Margin="0,12,0,0" Text="{Binding ViewModel.CurrentVersion, StringFormat=Current version: {0}}" />
    <TextBlock Margin="0,6,0,0" Text="{Binding ViewModel.TargetVersion, StringFormat=Available version: {0}}" />

    <TextBlock Margin="0,20,0,0" FontSize="16" FontWeight="Medium" Text="Release notes" />
    <TextBox
      Margin="0,8,0,0"
      MinHeight="120"
      AcceptsReturn="True"
      IsReadOnly="True"
      Text="{Binding ViewModel.ReleaseNotes}"
      TextWrapping="Wrap"
      VerticalScrollBarVisibility="Auto"
    />
  </StackPanel>
</Page>
